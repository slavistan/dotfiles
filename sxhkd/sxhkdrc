# Run an application.
mod4 + d
	dmenu_run -p "Run:"

# Spawn new terminal.
mod4 + Return
	st

# Spawn a new terminal opening lf immediately.
mod4 + ctrl + Return
	open-claude.sh

# Open rofimoji.
mod4 + shift + m
	rofimoji

# Open rofimoji with symbols relevant to my Obsidian workflow.
mod4 + m
	rofimoji -f ~/prj/dotfiles/rofimoji/obsidian.csv

# Choose keyboard layout.
shift + mod4 + F12
	selxkbmap

# Exit dwm.
ctrl + shift + mod4 + q
	dwmquit

# Take a snapshot.
mod4 + n
	snapchad --select-area

# Reload sxhkd.
mod4 + F5
	pkill -SIGUSR1 sxhkd
